@page "/host"
@rendermode InteractiveServer
@using QRCoder
@inject NavigationManager Nav
@inject IGameService GameService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Host — VibeCheck</PageTitle>

@if (_error != null)
{
    <div class="fixed top-4 right-4 bg-error text-on-error px-4 py-3 rounded-xl z-50 flex items-center gap-3 shadow-lg">
        <span class="material-symbols-outlined">error</span>
        <span>@_error</span>
        <button @onclick="() => _error = null" class="ml-2 font-bold text-lg leading-none">✕</button>
    </div>
}

@if (_phase != HostPhase.SelectQuiz)
{
    <button @onclick="ToggleMute" class="fixed top-3 right-3 z-40 bg-surface-container shadow-md rounded-full p-2">
        <span class="material-symbols-outlined text-on-surface">@(_muted ? "volume_off" : "volume_up")</span>
    </button>
}

@switch (_phase)
{
    case HostPhase.SelectQuiz:
        <div class="flex flex-col items-center justify-center min-h-screen gap-6 p-gutter">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-primary text-4xl">sensors</span>
                <span class="font-headline text-headline-md text-primary font-black tracking-tighter">VibeCheck</span>
            </div>
            <h1 class="text-body-lg font-bold text-on-surface">Select a quiz to host</h1>
            <div class="w-full max-w-md flex flex-col gap-3">
                @foreach (var quiz in _quizzes)
                {
                    var q = quiz;
                    <button @onclick="() => CreateSession(q.Id)"
                            class="w-full bg-primary-container text-on-primary-container rounded-xl px-6 py-4 text-left flex items-center justify-between hover:bg-primary hover:text-on-primary transition-colors">
                        <div>
                            <p class="font-bold text-body-lg">@quiz.Title</p>
                            <p class="text-body-md opacity-75">@quiz.Questions.Count question@(quiz.Questions.Count != 1 ? "s" : "")</p>
                        </div>
                        <span class="material-symbols-outlined text-3xl">play_circle</span>
                    </button>
                }
                @if (!_quizzes.Any())
                {
                    <p class="text-on-surface-variant text-center text-body-md">No quizzes available.</p>
                }
            </div>
        </div>
        break;

    case HostPhase.Lobby:
        <div class="flex flex-col items-center justify-center min-h-screen gap-6 p-gutter">
            <p class="text-on-surface-variant text-body-md font-medium tracking-wide uppercase">Game PIN</p>
            <div class="text-headline-pin text-primary font-black tracking-widest select-all">@_pin</div>
            <p class="text-on-surface-variant text-body-md">Join at <span class="font-bold text-primary">@Nav.BaseUri.TrimEnd('/')@("/play")</span></p>
            @if (!string.IsNullOrEmpty(_qrSvg))
            {
                <div class="bg-white rounded-2xl p-3 w-40 h-40 flex items-center justify-center">
                    @((MarkupString)_qrSvg)
                </div>
            }
            <div class="bg-surface-container rounded-2xl px-8 py-5 flex flex-col items-center gap-2 w-full max-w-sm">
                <span class="text-headline-md font-black text-primary">@_playerCount</span>
                <span class="text-on-surface-variant text-body-md">player@(_playerCount != 1 ? "s" : "") joined</span>
                @if (_players.Any())
                {
                    <div class="flex flex-wrap gap-2 mt-2 justify-center">
                        @foreach (var name in _players)
                        {
                            <span class="bg-primary-fixed text-on-primary-fixed px-3 py-1 rounded-full text-body-md font-medium">@name</span>
                        }
                    </div>
                }
            </div>
            <button @onclick="StartGame" disabled="@(_playerCount == 0)"
                    class="bg-secondary text-on-secondary font-bold text-body-lg px-10 py-4 rounded-full disabled:opacity-40 hover:opacity-90 transition-opacity">
                Start Game
            </button>
            <p class="text-on-surface-variant text-body-md">@_quizTitle</p>
        </div>
        break;

    case HostPhase.Question:
        <div class="flex flex-col min-h-screen bg-primary">
            <div class="flex items-center justify-between px-6 py-4 text-on-primary">
                <span class="text-body-md font-medium opacity-75">Q @(_question!.Index + 1) / @_question.Total</span>
                <CountdownRing SecondsLeft="@_secsLeft" TimeLimitSec="@(_question?.TimeLimitSec ?? 20)" Class="w-16 h-16" />
                <span class="text-body-md font-medium opacity-75">@_answeredCount / @_playerCount answered</span>
            </div>
            <div class="flex-1 flex flex-col items-center justify-center gap-6 px-6 pb-6">
                <div class="bg-on-primary text-primary rounded-2xl px-8 py-6 w-full max-w-2xl text-center shadow">
                    <p class="text-body-lg font-bold">@_question!.Text</p>
                </div>
                <div class="grid grid-cols-2 gap-4 w-full max-w-2xl">
                    @foreach (var opt in _question!.Options)
                    {
                        <div class="@OptionBg(opt.Index) text-white rounded-2xl px-5 py-4 flex items-center gap-3 shadow">
                            <span class="material-symbols-outlined text-2xl symbol-fill">@OptionIcon(opt.Index)</span>
                            <span class="font-bold text-body-lg">@opt.Text</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        break;

    case HostPhase.ShowAnswers:
        <div class="flex flex-col items-center justify-center min-h-screen gap-6 p-gutter">
            @if (_question != null && _correctIndex >= 0 && _correctIndex < _question.Options.Count)
            {
                <div class="flex items-center gap-3 text-secondary">
                    <span class="material-symbols-outlined text-4xl symbol-fill">check_circle</span>
                    <span class="text-headline-md font-black">@_question.Options[_correctIndex].Text</span>
                </div>
                <p class="text-on-surface-variant text-body-md">Correct answer</p>
            }
            @if (_question != null)
            {
                var totalAnswered = _answerCounts.Length > 0 ? _answerCounts.Sum() : 0;
                <div class="w-full max-w-lg flex flex-col gap-3">
                    @foreach (var opt in _question.Options)
                    {
                        var count = opt.Index < _answerCounts.Length ? _answerCounts[opt.Index] : 0;
                        var pct = totalAnswered > 0 ? (int)((double)count / totalAnswered * 100) : 0;
                        var isCorrect = opt.Index == _correctIndex;
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined @(isCorrect ? "text-secondary" : "text-on-surface-variant") symbol-fill w-7">@OptionIcon(opt.Index)</span>
                            <span class="text-body-md text-on-surface w-28 truncate">@opt.Text</span>
                            <div class="flex-1 bg-surface-container-high rounded-full h-5 overflow-hidden">
                                <div class="h-full @(isCorrect ? "bg-secondary" : "bg-primary-container") rounded-full transition-all duration-500"
                                     style="width: @(pct)%"></div>
                            </div>
                            <span class="text-body-md text-on-surface-variant w-14 text-right">@count/@totalAnswered</span>
                        </div>
                    }
                </div>
            }
            <button @onclick="NextStep"
                    class="bg-primary text-on-primary font-bold text-body-lg px-10 py-4 rounded-full hover:opacity-90 transition-opacity">
                Next
            </button>
        </div>
        break;

    case HostPhase.Leaderboard:
        <div class="flex flex-col items-center justify-center min-h-screen gap-6 p-gutter">
            <span class="material-symbols-outlined text-primary text-5xl">leaderboard</span>
            <h2 class="text-headline-md font-black text-on-surface">Leaderboard</h2>
            <div class="w-full max-w-sm flex flex-col gap-2">
                @foreach (var entry in _leaderboard.Take(5))
                {
                    <div class="flex items-center gap-3 bg-surface-container rounded-xl px-5 py-3">
                        <span class="text-body-lg font-black text-primary w-6">@RankEmoji(entry.Rank)</span>
                        <span class="flex-1 text-body-lg font-medium text-on-surface">@entry.Nickname</span>
                        <span class="text-body-lg font-black text-primary">@entry.Score</span>
                    </div>
                }
            </div>
            <button @onclick="NextStep"
                    class="bg-primary text-on-primary font-bold text-body-lg px-10 py-4 rounded-full hover:opacity-90 transition-opacity">
                Next Question
            </button>
        </div>
        break;

    case HostPhase.Finished:
        <div class="flex flex-col items-center justify-center min-h-screen gap-6 p-gutter">
            <span class="material-symbols-outlined text-primary text-6xl symbol-fill">emoji_events</span>
            <h2 class="text-headline-md font-black text-on-surface">Game Over!</h2>
            <div class="w-full max-w-sm flex flex-col gap-2">
                @foreach (var entry in _leaderboard.Take(5))
                {
                    <div class="flex items-center gap-3 @(entry.Rank == 1 ? "bg-secondary-container" : "bg-surface-container") rounded-xl px-5 py-3">
                        <span class="text-body-lg font-black text-primary w-6">@RankEmoji(entry.Rank)</span>
                        <span class="flex-1 text-body-lg font-medium text-on-surface">@entry.Nickname</span>
                        <span class="text-body-lg font-black text-primary">@entry.Score</span>
                    </div>
                }
            </div>
            <div class="flex gap-3">
                <button @onclick="ExportResults"
                        class="flex items-center gap-2 border-2 border-primary text-primary font-bold text-body-lg px-7 py-4 rounded-full hover:bg-primary hover:text-on-primary transition-colors">
                    <span class="material-symbols-outlined">download</span>
                    Export CSV
                </button>
                <button @onclick="GoHome"
                        class="bg-primary text-on-primary font-bold text-body-lg px-10 py-4 rounded-full hover:opacity-90 transition-opacity">
                    Play Again
                </button>
            </div>
        </div>
        break;
}

@code {
    private enum HostPhase { SelectQuiz, Lobby, Question, ShowAnswers, Leaderboard, Finished }

    HubConnection? _hub;
    HostPhase _phase = HostPhase.SelectQuiz;
    string? _error;
    List<Quiz> _quizzes = [];

    string _pin = "";
    string _quizTitle = "";
    string _qrSvg = "";
    int _playerCount = 0;
    readonly List<string> _players = [];

    QuestionPayload? _question;
    int _secsLeft;
    int _answeredCount;

    int _correctIndex = -1;
    List<ScoreEntry> _scores = [];
    int[] _answerCounts = [];

    List<LeaderEntry> _leaderboard = [];
    bool _muted;

    protected override void OnInitialized()
    {
        _quizzes = GameService.GetAllQuizzes().ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/gamehub"))
            .WithAutomaticReconnect()
            .AddJsonProtocol(o => o.PayloadSerializerOptions.PropertyNameCaseInsensitive = true)
            .Build();

        _hub.On<string, string, Guid>("SessionCreated", (pin, title, _) => InvokeAsync(() =>
        {
            _pin = pin; _quizTitle = title;
            var url = $"{Nav.BaseUri.TrimEnd('/')}/play/{pin}";
            var qrData = new QRCodeGenerator().CreateQrCode(url, QRCodeGenerator.ECCLevel.M);
            _qrSvg = new SvgQRCode(qrData).GetGraphic(5);
            _phase = HostPhase.Lobby; StateHasChanged();
        }));

        _hub.On<string, int>("PlayerJoined", (nickname, count) => InvokeAsync(() =>
        {
            _players.Add(nickname); _playerCount = count; StateHasChanged();
        }));

        _hub.On<string, int>("PlayerLeft", (nickname, count) => InvokeAsync(() =>
        {
            _players.Remove(nickname); _playerCount = count; StateHasChanged();
        }));

        _hub.On("GameStarted", () => InvokeAsync(async () =>
        {
            try { await JS.InvokeVoidAsync("gameInterop.playGameStart"); } catch { }
            try { await JS.InvokeVoidAsync("gameInterop.playBgMusic"); } catch { }
            StateHasChanged();
        }));

        _hub.On<QuestionPayload>("QuestionStarted", payload => InvokeAsync(async () =>
        {
            _question = payload; _secsLeft = payload.TimeLimitSec; _answeredCount = 0;
            _phase = HostPhase.Question;
            try { await JS.InvokeVoidAsync("gameInterop.playQuestionStart"); } catch { }
            StateHasChanged();
        }));

        _hub.On<int>("TimerTick", secs => InvokeAsync(async () =>
        {
            _secsLeft = secs;
            if (secs <= 5 && secs > 0)
                try { await JS.InvokeVoidAsync("gameInterop.playTimerTick"); } catch { }
            StateHasChanged();
        }));

        _hub.On<int>("AnswerCountUpdated", count => InvokeAsync(() => { _answeredCount = count; StateHasChanged(); }));

        _hub.On<int, List<ScoreEntry>, int[]>("QuestionEnded", (correctIndex, scores, answerCounts) => InvokeAsync(() =>
        {
            _correctIndex = correctIndex; _scores = scores; _answerCounts = answerCounts;
            _phase = HostPhase.ShowAnswers; StateHasChanged();
        }));

        _hub.On<int, int, int>("HostRejoined", (phaseInt, _, secondsLeft) => InvokeAsync(() =>
        {
            _secsLeft = secondsLeft;
            if (phaseInt != 1) // ShowQuestion: QuestionStarted re-send handles the phase
            {
                _phase = phaseInt switch
                {
                    2 => HostPhase.ShowAnswers,
                    3 => HostPhase.Leaderboard,
                    4 => HostPhase.Finished,
                    _ => HostPhase.Lobby,
                };
            }
            StateHasChanged();
        }));

        _hub.On<List<LeaderEntry>>("LeaderboardUpdate", entries => InvokeAsync(() =>
        {
            _leaderboard = entries; _phase = HostPhase.Leaderboard; StateHasChanged();
        }));

        _hub.On<List<LeaderEntry>>("GameFinished", entries => InvokeAsync(async () =>
        {
            _leaderboard = entries; _phase = HostPhase.Finished;
            try { await JS.InvokeVoidAsync("gameInterop.stopBgMusic"); } catch { }
            try { await JS.InvokeVoidAsync("gameInterop.playFinish"); } catch { }
            try { await JS.InvokeVoidAsync("gameInterop.launchConfetti"); } catch { }
            StateHasChanged();
        }));

        _hub.On<string>("Error", msg => InvokeAsync(() => { _error = msg; StateHasChanged(); }));

        await _hub.StartAsync();

        _hub.Reconnected += async _ =>
        {
            if (!string.IsNullOrEmpty(_pin))
                await _hub!.SendAsync("HostJoin", _pin);
        };
    }

    private async Task CreateSession(Guid quizId)
    {
        if (_hub?.State != HubConnectionState.Connected) return;
        await _hub.SendAsync("HostCreateSession", quizId);
    }

    private async Task StartGame()
    {
        if (_hub?.State != HubConnectionState.Connected) return;
        await _hub.SendAsync("StartGame", _pin);
    }

    private async Task NextStep()
    {
        if (_hub?.State != HubConnectionState.Connected) return;
        await _hub.SendAsync("NextStep", _pin);
    }

    private static string OptionBg(int i) => i switch
    {
        0 => "bg-k-red",
        1 => "bg-k-blue",
        2 => "bg-k-yellow",
        _ => "bg-k-green",
    };

    private static string OptionIcon(int i) => i switch
    {
        0 => "change_history",
        1 => "diamond",
        2 => "circle",
        _ => "square",
    };

    private static string RankEmoji(int rank) => rank switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => $"{rank}.",
    };

    private async Task ToggleMute()
    {
        _muted = !_muted;
        try { await JS.InvokeVoidAsync("gameInterop.setMuted", _muted); } catch { }
    }

    private async Task ExportResults()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Rank,Nickname,Score");
        foreach (var e in _leaderboard)
            sb.AppendLine($"{e.Rank},{EscapeCsv(e.Nickname)},{e.Score}");
        var filename = $"results-{_pin}-{DateTime.Now:yyyyMMdd-HHmm}.csv";
        try { await JS.InvokeVoidAsync("gameInterop.downloadCsv", filename, sb.ToString()); } catch { }
    }

    private static string EscapeCsv(string v) =>
        v.Contains(',') || v.Contains('"') ? $"\"{v.Replace("\"", "\"\"")}\"" : v;

    private void GoHome() => Nav.NavigateTo("/host");

    public async ValueTask DisposeAsync()
    {
        if (_hub != null) await _hub.DisposeAsync();
    }
}
