@page "/"

<PageTitle>VibeCheck</PageTitle>

<div class="flex flex-col items-center justify-center min-h-screen bg-background gap-6 p-gutter">
    <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-4xl">sensors</span>
        <span class="font-headline text-headline-md tracking-tighter text-primary font-black">VibeCheck</span>
    </div>
    <p class="text-on-surface-variant text-body-lg">Real-time classroom quizzes</p>
    <div class="flex flex-col gap-3 w-full max-w-xs mt-2">
        <a href="/host"
           class="flex items-center justify-center gap-2 bg-primary text-on-primary font-bold text-body-lg py-4 rounded-full hover:opacity-90 transition-opacity">
            <span class="material-symbols-outlined">cast</span>
            Host a Game
        </a>
        <a href="/play"
           class="flex items-center justify-center gap-2 bg-surface-container text-on-surface font-bold text-body-lg py-4 rounded-full hover:bg-surface-container-high transition-colors">
            <span class="material-symbols-outlined">sports_esports</span>
            Join a Game
        </a>
    </div>
</div>
