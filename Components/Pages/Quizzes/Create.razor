@page "/quizzes/create"
@rendermode InteractiveServer
@inject IGameService GameService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>New Quiz — VibeCheck</PageTitle>

<div class="flex flex-col min-h-screen p-gutter max-w-2xl mx-auto gap-5 pb-28">
    <div class="flex items-center gap-3 pt-6">
        <a href="/quizzes" class="text-on-surface-variant hover:text-primary transition-colors">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-headline-md font-black text-on-surface">New Quiz</h1>
    </div>

    <div class="flex flex-col gap-1">
        <label class="text-body-md font-medium text-on-surface-variant">Quiz Title</label>
        <input @bind="_title" @bind:event="oninput"
               placeholder="e.g. General Knowledge"
               maxlength="100"
               class="bg-surface-container text-on-surface rounded-xl px-4 py-3 text-body-lg focus:outline-none focus:ring-2 focus:ring-primary" />
    </div>

    <div class="bg-surface-container rounded-2xl px-5 py-4 flex flex-col gap-3">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 text-on-surface-variant">
                <span class="material-symbols-outlined">upload_file</span>
                <span class="text-body-md font-medium">Import from CSV</span>
            </div>
            <button @onclick="DownloadSample" class="text-primary text-body-md hover:underline flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">download</span>
                Sample CSV
            </button>
        </div>
        <p class="text-body-md text-on-surface-variant text-xs">Format: Question, OptionA, OptionB, OptionC, OptionD, CorrectIndex (0–3), TimeLimitSec</p>
        <InputFile OnChange="ImportCsv" accept=".csv"
                   class="text-body-md text-on-surface-variant file:mr-3 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:bg-primary file:text-on-primary file:font-bold file:cursor-pointer hover:file:opacity-90" />
        @if (_importMsg != null)
        {
            <p class="text-body-md @(_importErr ? "text-error" : "text-secondary") font-medium">@_importMsg</p>
        }
    </div>

    @for (int qi = 0; qi < _questions.Count; qi++)
    {
        var q = _questions[qi];
        var qIdx = qi;
        <div @key="q.Id" class="bg-surface-container rounded-2xl p-5 flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <p class="font-bold text-body-lg text-on-surface">Question @(qIdx + 1)</p>
                <div class="flex items-center gap-2">
                    <select @bind="q.TimeLimitSec"
                            class="bg-surface-container-high text-on-surface rounded-lg px-3 py-1.5 text-body-md focus:outline-none focus:ring-2 focus:ring-primary">
                        <option value="5">5s</option>
                        <option value="10">10s</option>
                        <option value="15">15s</option>
                        <option value="20">20s</option>
                        <option value="30">30s</option>
                        <option value="60">60s</option>
                    </select>
                    @if (_questions.Count > 1)
                    {
                        <button @onclick="() => RemoveQuestion(qIdx)"
                                class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error-container rounded-lg transition-colors">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    }
                </div>
            </div>

            <input @bind="q.Text" @bind:event="oninput"
                   placeholder="Question text"
                   class="bg-surface-container-high text-on-surface rounded-xl px-4 py-3 text-body-md focus:outline-none focus:ring-2 focus:ring-primary" />

            <div class="grid grid-cols-2 gap-3">
                @for (int oi = 0; oi < 4; oi++)
                {
                    var oIdx = oi;
                    <label class="flex items-center gap-2 rounded-xl p-3 cursor-pointer border-2 transition-colors
                                  @(q.CorrectIndex == oIdx ? "bg-secondary-container border-secondary" : "bg-surface-container-high border-transparent")">
                        <input type="radio"
                               name="correct-@q.Id"
                               checked="@(q.CorrectIndex == oIdx)"
                               @onchange="() => q.CorrectIndex = oIdx"
                               class="accent-primary shrink-0" />
                        <span class="material-symbols-outlined text-sm symbol-fill @OptionIconColor(oIdx)">@OptionIcon(oIdx)</span>
                        <input @bind="q.Options[oIdx]" @bind:event="oninput"
                               placeholder="Option @(oIdx + 1)"
                               class="bg-transparent flex-1 min-w-0 focus:outline-none text-body-md text-on-surface placeholder:text-on-surface-variant/50" />
                    </label>
                }
            </div>
            <p class="text-body-md text-on-surface-variant text-xs">Select radio button to mark correct answer</p>
        </div>
    }

    @if (_questions.Count < GameConstants.MaxQuestionsPerQuiz)
    {
        <button @onclick="AddQuestion"
                class="flex items-center justify-center gap-2 border-2 border-dashed border-outline-variant text-on-surface-variant rounded-2xl py-4 hover:border-primary hover:text-primary transition-colors">
            <span class="material-symbols-outlined">add_circle</span>
            Add Question
        </button>
    }

    @if (_error != null)
    {
        <div class="flex items-center gap-2 text-error bg-error-container px-4 py-3 rounded-xl">
            <span class="material-symbols-outlined">error</span>
            <p class="text-body-md font-medium">@_error</p>
        </div>
    }
</div>

<div class="fixed bottom-0 left-0 right-0 bg-surface-container-high border-t border-outline-variant px-gutter py-4 flex items-center justify-between gap-4">
    <p class="text-on-surface-variant text-body-md">@_questions.Count question@(_questions.Count != 1 ? "s" : "")</p>
    <button @onclick="Submit"
            class="bg-primary text-on-primary font-bold text-body-lg px-10 py-3 rounded-full hover:opacity-90 transition-opacity">
        Create Quiz
    </button>
</div>

@code {
    private class QuestionFormModel
    {
        public Guid Id { get; } = Guid.NewGuid();
        public string Text { get; set; } = "";
        public int TimeLimitSec { get; set; } = 20;
        public string[] Options { get; } = ["", "", "", ""];
        public int CorrectIndex { get; set; } = 0;
    }

    string _title = "";
    string? _error;
    string? _importMsg;
    bool _importErr;
    List<QuestionFormModel> _questions = [new QuestionFormModel()];

    private void AddQuestion() => _questions.Add(new QuestionFormModel());

    private async Task ImportCsv(InputFileChangeEventArgs e)
    {
        _importMsg = null; _importErr = false;
        try
        {
            using var reader = new System.IO.StreamReader(e.File.OpenReadStream(maxAllowedSize: 1_048_576));
            var text = await reader.ReadToEndAsync();
            var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
            var imported = new List<QuestionFormModel>();
            foreach (var line in lines.Skip(1))
            {
                var cols = ParseCsvLine(line);
                if (cols.Length < 6 || string.IsNullOrWhiteSpace(cols[0])) continue;
                var q = new QuestionFormModel { Text = cols[0].Trim() };
                q.Options[0] = cols.Length > 1 ? cols[1].Trim() : "";
                q.Options[1] = cols.Length > 2 ? cols[2].Trim() : "";
                q.Options[2] = cols.Length > 3 ? cols[3].Trim() : "";
                q.Options[3] = cols.Length > 4 ? cols[4].Trim() : "";
                q.CorrectIndex = cols.Length > 5 && int.TryParse(cols[5].Trim(), out int ci) ? Math.Clamp(ci, 0, 3) : 0;
                int[] allowed = [5, 10, 15, 20, 30, 60];
                q.TimeLimitSec = cols.Length > 6 && int.TryParse(cols[6].Trim(), out int tl) && allowed.Contains(tl) ? tl : 20;
                imported.Add(q);
            }
            if (imported.Count == 0) { _importMsg = "No valid rows found."; _importErr = true; return; }
            _questions = imported;
            _importMsg = $"Imported {imported.Count} question{(imported.Count != 1 ? "s" : "")}.";
        }
        catch { _importMsg = "Failed to parse CSV. Check file format and try again."; _importErr = true; }
    }

    private static string[] ParseCsvLine(string line)
    {
        var result = new List<string>();
        bool inQuotes = false;
        var cur = new System.Text.StringBuilder();
        foreach (char c in line.TrimEnd('\r'))
        {
            if (c == '"') inQuotes = !inQuotes;
            else if (c == ',' && !inQuotes) { result.Add(cur.ToString()); cur.Clear(); }
            else cur.Append(c);
        }
        result.Add(cur.ToString());
        return result.ToArray();
    }

    private async Task DownloadSample()
    {
        const string sample =
            "Question,OptionA,OptionB,OptionC,OptionD,CorrectIndex,TimeLimitSec\r\n" +
            "\"Capital of France?\",Paris,London,Berlin,Rome,0,20\r\n" +
            "\"2 + 2 = ?\",3,4,5,6,1,10\r\n" +
            "\"Largest planet in solar system?\",Earth,Mars,Jupiter,Saturn,2,20\r\n";
        await JS.InvokeVoidAsync("gameInterop.downloadCsv", "quiz-sample.csv", sample);
    }

    private void RemoveQuestion(int index)
    {
        if (_questions.Count > 1) _questions.RemoveAt(index);
    }

    private void Submit()
    {
        _error = null;
        if (_title.Trim().Length == 0) { _error = "Quiz title is required."; return; }

        for (int i = 0; i < _questions.Count; i++)
        {
            var q = _questions[i];
            if (q.Text.Trim().Length == 0) { _error = $"Question {i + 1}: enter question text."; return; }
            if (q.Options.Any(o => o.Trim().Length == 0)) { _error = $"Question {i + 1}: fill in all 4 options."; return; }
        }

        try
        {
            var dtos = _questions.Select(q => new QuizQuestionDto(
                q.Text.Trim(),
                q.Options.Select((o, i) => new QuizOption(o.Trim(), i == q.CorrectIndex)).ToList(),
                q.TimeLimitSec
            )).ToArray();
            GameService.CreateQuiz(_title.Trim(), dtos);
            Nav.NavigateTo("/quizzes");
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
        }
    }

    private static string OptionIconColor(int i) => i switch
    {
        0 => "text-k-red",
        1 => "text-k-blue",
        2 => "text-k-yellow",
        _ => "text-k-green",
    };

    private static string OptionIcon(int i) => i switch
    {
        0 => "change_history",
        1 => "diamond",
        2 => "circle",
        _ => "square",
    };
}
