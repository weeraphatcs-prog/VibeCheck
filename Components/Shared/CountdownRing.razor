@namespace KahootClone.Components.Shared

<svg viewBox="0 0 120 120" class="@Class">
    <circle cx="60" cy="60" r="54" fill="none" stroke="#374151" stroke-width="12" />
    <circle cx="60" cy="60" r="54" fill="none"
            stroke="@RingColor"
            stroke-width="12"
            stroke-dasharray="339.3"
            stroke-dashoffset="@DashOffset.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
            stroke-linecap="round"
            transform="rotate(-90 60 60)"
            style="transition: stroke-dashoffset 1s linear, stroke 0.5s ease" />
    <text x="60" y="68" text-anchor="middle" font-family="Rubik" font-size="28" font-weight="900" fill="@RingColor">@SecondsLeft</text>
</svg>

@code {
    [Parameter] public int SecondsLeft { get; set; }
    [Parameter] public int TimeLimitSec { get; set; }
    [Parameter] public string Class { get; set; } = "w-32 h-32";

    private double Ratio => TimeLimitSec > 0 ? (double)SecondsLeft / TimeLimitSec : 0;
    private double DashOffset => 339.3 * (1 - Ratio);

    private string RingColor => Ratio switch
    {
        > 0.5  => "#26890C",
        > 0.25 => "#D89E00",
        _      => "#E21B3C",
    };
}
